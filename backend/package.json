{
  "name": "signforge-backend",
  "version": "1.0.0",
  "description": "SignForge - E-Signature & Contract Lifecycle Management Platform",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "npm run deploy",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main",
    "db:sanitize": "node scripts/sanitize-prisma-migrations.js prisma/migrations",
    "db:migrate": "npm run db:sanitize && prisma migrate deploy",
    "db:seed": "prisma db seed",
    "deploy": "npm run db:migrate && npm run db:seed && npm run start:prod",
    "test": "jest --passWithNoTests"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@prisma/client": "^5.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "bcrypt": "^5.1.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/node": "^20.11.0",
    "prisma": "^5.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "ts-loader": "^9.5.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1"
  }
}
